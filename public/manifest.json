{
  "id": "/",
  "name": "OBedTech Instagram Downloader",
  "short_name": "IGDownloader",
  "description": "Download Instagram Reels, videos, photos and carousels in full quality. Free, fast, and no login required.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "background_color": "#080B14",
  "theme_color": "#E96A36",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["utilities", "productivity", "social"],
  "prefer_related_applications": false,

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "handle_links": "preferred",

  "scope_extensions": [
    { "origin": "https://igdl-nqpo.onrender.com" }
  ],

  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/plain": [".txt"],
        "text/uri-list": [".uri"]
      },
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+igdownload",
      "url": "/?url=%s"
    }
  ],

  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "url",
      "url": "url"
    }
  },

  "screenshots": [
    {
      "src": "/screenshots/screenshot-mobile.png",
      "sizes": "640x1136",
      "type": "image/png",
      "platform": "narrow",
      "label": "OBedTech Instagram Downloader — Mobile view with video preview and download"
    },
    {
      "src": "/screenshots/screenshot-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "platform": "wide",
      "label": "OBedTech Instagram Downloader — Desktop view"
    }
  ],

  "icons": [
    { "src": "/icons/icon-72x72.png",   "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96x96.png",   "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128x128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-152x152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],

  "shortcuts": [
    {
      "name": "Download Media",
      "short_name": "Download",
      "description": "Quickly download Instagram media",
      "url": "/?action=download",
      "icons": [{ "src": "/icons/icon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],

  "related_applications": [],
  "edge_side_panel": { "preferred_width": 480 }
}
